# ─── Core ─────────────────────────────────────────────────────────────────────
# Set to 'production' for secure session cookies (required when app is served over HTTPS).
# Set to 'development' only for local dev without HTTPS.
NODE_ENV=production
PORT=3001
APP_NAME=Oblihub

# Session / DB
SESSION_SECRET=change-this-in-production
DB_PASSWORD=changeme
DATABASE_URL=postgres://oblihub:changeme@localhost:5432/oblihub

# Origin used for CORS — must match the URL from which the client is served.
# With self-signed HTTPS, typically https://localhost:3101 (or your FQDN).
CLIENT_ORIGIN=https://localhost:3101

# Default admin created on first boot if users table is empty.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Docker socket path inside the server container.
DOCKER_SOCKET=/var/run/docker.sock

# ─── Feature flags (true / 1 / yes) ───────────────────────────────────────────
# Container web console (xterm via docker exec). Disabled by default.
ALLOW_CONSOLE=false
# Managed Docker Compose stacks (create / update / deploy compose from the UI).
ALLOW_STACK=false
# Integrated nginx reverse proxy (proxy hosts, Let's Encrypt, streams, redirects).
ALLOW_NGINX=false

# ─── Intervals ────────────────────────────────────────────────────────────────
# DISCOVERY_INTERVAL=30000       # ms — how often DiscoveryWorker scans Docker
# DEFAULT_CHECK_INTERVAL=60      # seconds — default image update check interval per stack

# ─── Docker Compose deployment ────────────────────────────────────────────────
OBLIHUB_VERSION=latest

# Client listen ports (host → container)
LISTEN_PORT=3100        # HTTP  → container :80
LISTEN_PORT_HTTPS=3101  # HTTPS → container :443 (self-signed by default)

# Integrated proxy listen ports (only if ALLOW_NGINX=true)
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
